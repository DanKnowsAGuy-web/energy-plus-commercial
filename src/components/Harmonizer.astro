---
// "The healing of a hotel" — merged scroll scene, v3.
// Grid power stays dirty the entire time: distortion is what the utility
// delivers. The harmonizer sits pressed against the building like a shield,
// and only what's behind it transforms. The circular device on the ground
// floor is the building meter; the
// pool/laundry drive drum sits just left of the elevator shaft. Sparks ride
// the riser while dirty; clean blue sine waves feed every line once healed.
import Disc from "./Disc.astro";

interface Props {
  lang?: "en" | "es";
}
const { lang = "en" } = Astro.props;

const t = {
  en: {
    title: "What dirty power does, and what the harmonizer undoes.",
    card1: "Modern equipment pulls power in fast pulses instead of a steady draw, and most of that instability starts inside your own building.",
    navAria: "Step through the four stages",
    prevAria: "Previous stage",
    nextAria: "Next stage",
    nextLabel: "See what happens",
    nextAfter: "Next",
    svgAria: "Distorted grid current flows toward a commercial building cross-section, running its HVAC drives, compressors, and elevator motor hot; a harmonizer drops in against the building like a shield, and everything behind it heals: clean blue current feeds every line and the windows warm as the building settles. The grid side stays distorted throughout.",
    boxLabel: "Harmonizer",
    boxSub: "at the panel",
    billLabel: "Your utility bill",
    rUseful: "Useful energy",
    rHeat: "Lost as heat",
    rPf: "Power-factor penalty",
    rHarmo: "Harmonizer",
    rPay: "What you pay",
    billNote: "Illustrative split, set by your own utility data.",
    offbillEyebrow: "Off the bill, too",
    offbill: "Dirty power also takes <strong>5+ years</strong> off a large HVAC unit, the kind that costs <strong>tens of thousands</strong> to replace. That bill never reaches your meter.",
    mTitle: "What dirty power does, and what the harmonizer undoes.",
    mStep1: "Your motors, elevators, and air conditioners pull electricity in rough, uneven bursts. That roughness builds up inside your building, not out on the grid.",
    mStep2: "Rough power gets less done, so your building pulls more electricity to run the same machines. The waste shows up on every bill.",
    mStep3: "The harmonizer cleans up the power where it enters your building, before the roughness reaches your equipment. Your motors and compressors run cooler and steadier.",
    mStep4: "Lower bills, fewer breakdowns, and equipment that lasts longer.",
    vizDirtyAria: "A rough, distorted current waveform.",
    vizCleanAria: "A clean, steady current waveform.",
    capDirty: "Rough, uneven current",
    capChip: "Harmonizer · at the panel",
    mStat: "<strong>8 to 14%</strong> energy savings, verified at buildings like yours.",
  },
  es: {
    title: "Lo que hace la energía sucia, y lo que el armonizador deshace.",
    card1: "El equipo moderno consume energía en pulsos rápidos en lugar de una demanda constante, y la mayor parte de esa inestabilidad comienza dentro de su propio edificio.",
    navAria: "Recorra las cuatro etapas",
    prevAria: "Etapa anterior",
    nextAria: "Siguiente etapa",
    nextLabel: "Vea lo que pasa",
    nextAfter: "Siguiente",
    svgAria: "La corriente distorsionada de la red fluye hacia la sección transversal de un edificio comercial, manteniendo calientes sus variadores de HVAC, compresores y el motor del ascensor; un armonizador se coloca contra el edificio como un escudo, y todo lo que queda detrás sana: una corriente azul y limpia alimenta cada línea y las ventanas se iluminan a medida que el edificio se estabiliza. El lado de la red permanece distorsionado en todo momento.",
    boxLabel: "Armonizador",
    boxSub: "en el tablero",
    billLabel: "Su factura de luz",
    rUseful: "Energía útil",
    rHeat: "Perdido como calor",
    rPf: "Penalización por factor de potencia",
    rHarmo: "Armonizador",
    rPay: "Lo que usted paga",
    billNote: "División ilustrativa, definida según los datos de su propia compañía de servicios.",
    offbillEyebrow: "Fuera de la factura, también",
    offbill: "La energía sucia también le quita <strong>más de 5 años</strong> de vida a una unidad grande de HVAC, de las que cuestan <strong>decenas de miles</strong> reemplazar. Esa factura nunca llega a su medidor.",
    mTitle: "Lo que hace la energía sucia, y lo que el armonizador deshace.",
    mStep1: "Sus motores, ascensores y aires acondicionados consumen electricidad en ráfagas bruscas y desiguales. Esa aspereza se acumula dentro de su edificio, no afuera en la red.",
    mStep2: "La energía áspera rinde menos, así que su edificio consume más electricidad para mover las mismas máquinas. El desperdicio aparece en cada factura.",
    mStep3: "El armonizador limpia la energía donde entra a su edificio, antes de que la aspereza llegue a su equipo. Sus motores y compresores funcionan más fríos y estables.",
    mStep4: "Facturas más bajas, menos averías y equipos que duran más.",
    vizDirtyAria: "Una forma de onda de corriente áspera y distorsionada.",
    vizCleanAria: "Una forma de onda de corriente limpia y constante.",
    capDirty: "Corriente áspera y desigual",
    capChip: "Armonizador · en el tablero",
    mStat: "<strong>8 a 14%</strong> de ahorro de energía, verificado en edificios como el suyo.",
  },
}[lang];

const cards = {
  en: [
    "Your motors, elevators, and air conditioners pull electricity in rough, uneven bursts. That roughness builds up inside your building, not out on the grid.",
    "Rough power gets less done, so your building pulls more electricity to run the same machines. Your meter counts the waste, and it shows up on every bill.",
    "The harmonizer cleans up the power where it enters your building, before the roughness reaches your equipment. Your motors and compressors run cooler and steadier.",
    "Lower bills, fewer breakdowns, and equipment that lasts longer. Verified at buildings like yours: 8 to 14 percent energy savings.",
  ],
  es: [
    "Sus motores, ascensores y aires acondicionados consumen electricidad en ráfagas bruscas y desiguales. Esa aspereza se acumula dentro de su edificio, no afuera en la red.",
    "La energía áspera rinde menos, así que su edificio consume más electricidad para mover las mismas máquinas. Su medidor cuenta el desperdicio, y aparece en cada factura.",
    "El armonizador limpia la energía donde entra a su edificio, antes de que la aspereza llegue a su equipo. Sus motores y compresores funcionan más fríos y estables.",
    "Facturas más bajas, menos averías y equipos que duran más. Verificado en edificios como el suyo: 8 a 14 por ciento de ahorro de energía.",
  ],
}[lang];
const X0 = 80;
const WAVE_END = 418; // reaches the building until the shield clips it back
const DRAW_W = (WAVE_END - X0) * 2;
const midY = 280;
const amp = 22;
const N = 240;

function wave() {
  // mildly distorted: some noise arrives with grid power, but the violent
  // distortion is made inside the building (see card 1)
  const cycles = 7;
  let d = "";
  for (let i = 0; i <= N; i++) {
    const x = X0 + (i / N) * DRAW_W;
    const t = (i / N) * Math.PI * 2 * cycles;
    const y = midY - amp * (0.84 * Math.sin(t) + 0.11 * Math.sin(3 * t + 0.6) + 0.07 * Math.sin(5 * t + 1.2));
    d += (i === 0 ? "M" : "L") + x.toFixed(1) + " " + y.toFixed(1) + " ";
  }
  return d.trim();
}
const distD = wave();

function mini(x1: number, x2: number, y: number) {
  const n = Math.max(16, Math.round((x2 - x1) / 6));
  const cycles = (x2 - x1) / 26;
  let d = "";
  for (let i = 0; i <= n; i++) {
    const x = x1 + (i / n) * (x2 - x1);
    const yy = y - 3.5 * Math.sin((i / n) * Math.PI * 2 * cycles);
    d += (i === 0 ? "M" : "L") + x.toFixed(1) + " " + yy.toFixed(1) + " ";
  }
  return d.trim();
}

const winRows = [270, 230, 190, 150, 110];
const winCols = [436, 468, 500, 532, 564];
const ptacs = [244, 204, 164];

// Compact, high-contrast waves for the mobile walkthrough (the desktop scene
// is too wide to stay legible on a phone, so mobile gets its own simple
// before/after visuals authored at a size that reads at ~320px wide).
function mWave(w: number, h: number, dirty: boolean) {
  const N = 120, mid = h / 2, amp = h * 0.34, cycles = dirty ? 6 : 4;
  let d = "";
  for (let i = 0; i <= N; i++) {
    const x = (i / N) * w;
    const t = (i / N) * Math.PI * 2 * cycles;
    const y = dirty
      ? mid - amp * (0.8 * Math.sin(t) + 0.13 * Math.sin(3 * t + 0.6) + 0.09 * Math.sin(5 * t + 1.2))
      : mid - amp * Math.sin(t);
    d += (i === 0 ? "M" : "L") + x.toFixed(1) + " " + y.toFixed(1) + " ";
  }
  return d.trim();
}
const mDirtyD = mWave(300, 60, true);
const mCleanD = mWave(300, 60, false);
---

<section class="hz" aria-labelledby="hz-title" data-cards={JSON.stringify(cards)} data-next-after={t.nextAfter}>
  <div class="hz__sticky">
    <div class="container hz__inner">
      <div class="hz__head">
        <h2 class="hz__title" id="hz-title">
          {t.title}
        </h2>
        <div class="hz__cardrow">
          <div class="hz__card" id="hz-card" aria-live="polite">
            <span class="hz__card-num" id="hz-card-num">1 / 4</span>
            <p class="hz__card-text" id="hz-card-text">
              {t.card1}
            </p>
          </div>
          <div class="hz__nav" role="group" aria-label={t.navAria}>
            <button type="button" class="hz__arrow hz__arrow--prev" id="hz-prev" aria-label={t.prevAria} disabled>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5l-7 7 7 7" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </button>
            <button type="button" class="hz__arrow hz__arrow--next is-cue" id="hz-next" aria-label={t.nextAria}>
              <span class="hz__arrow-label" id="hz-next-label">{t.nextLabel}</span>
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </button>
          </div>
        </div>
        <div class="hz__progress" aria-hidden="true">
          <span class="hz__progress-fill" id="hz-progress"></span>
        </div>
      </div>

      <figure class="hz__figure">
        <svg
          class="hz__svg"
          viewBox="0 0 760 360"
          role="img"
          aria-label={t.svgAria}
        >
          <defs>
            <clipPath id="hz-clip-dist">
              <rect id="hz-rect-d" x="80" y="250" width="338" height="62"></rect>
            </clipPath>
          </defs>

          <line class="hz__ground" x1="80" y1="330" x2="752" y2="330"></line>

          <!-- the line: the grid side never cleans up -->
          <line class="hz__axis" x1="80" y1={midY} x2="420" y2={midY}></line>
          <g clip-path="url(#hz-clip-dist)">
            <path class="hz__wave hz__wave--dist hz__flow" d={distD}></path>
          </g>

          <!-- building shell -->
          <g class="hz__bld" id="hz-bld">
            <rect class="hz__shell" id="hz-shell" x="420" y="40" width="240" height="290" rx="3"></rect>
            <rect class="hz__shell" x="510" y="20" width="56" height="20" rx="3"></rect>
            {[100, 140, 180, 220, 260, 300].map((y) => (
              <line class="hz__floor" x1="420" y1={y} x2="660" y2={y}></line>
            ))}
            <rect class="hz__shaft" x="614" y="100" width="36" height="230"></rect>

            {winRows.map((y, ri) => (
              <g class="hz__winrow" id={`hz-w${ri}`}>
                {winCols.map((x) => (
                  <rect class="hz__win" x={x} y={y} width="20" height="12" rx="1.5"></rect>
                ))}
              </g>
            ))}

            <!-- riser: red infection + mint healing overlay -->
            <path class="hz__riser hz__riser--red" id="hz-riser-red" d="M424 280 L424 64"></path>
            <path class="hz__riser hz__riser--mint" id="hz-riser-mint" d="M424 280 L424 64"></path>
            <path class="hz__riser hz__riser--red" id="hz-drop-red" d="M424 280 L424 312"></path>
            <path class="hz__riser hz__riser--mint" id="hz-drop-mint" d="M424 280 L424 312"></path>

            <!-- ground floor: the kWh meter (the circle) + reading beside it,
                 then the pool/laundry drive drum left of the shaft -->
            <g class="hz__load" id="hz-base">
              <line class="hz__stub" x1="424" y1="312" x2="446" y2="312"></line>
              <path class="hz__mini" d={mini(426, 444, 312)}></path>
              <circle class="hz__load-ln hz__meter-face" cx="455" cy="312" r="10"></circle>
              <line class="hz__load-ln" x1="455" y1="312" x2="461" y2="306"></line>
            </g>

            <!-- PTAC fleet -->
            {ptacs.map((y, i) => (
              <g class="hz__load" id={`hz-ptac${i}`}>
                <line class="hz__stub" x1="424" y1={y + 6} x2="582" y2={y + 6}></line>
                <path class="hz__mini" d={mini(428, 580, y + 6)}></path>
                <rect class="hz__load-ln" x="584" y={y} width="22" height="12" rx="2"></rect>
                <line class="hz__load-ln" x1="588" y1={y + 4} x2="598" y2={y + 4}></line>
                <circle class="hz__load-ln" cx="601" cy={y + 8} r="2.4"></circle>
                <circle class="hz__ripple" cx="595" cy={y + 6} r="7"></circle>
                {i === 0 && (
                  <>
                    <line class="hz__stub" x1="593" y1={y + 12} x2="593" y2="298"></line>
                    <rect class="hz__load-ln" x="578" y="298" width="30" height="28" rx="3"></rect>
                    <circle class="hz__load-ln" cx="593" cy="312" r="8"></circle>
                    <circle class="hz__load-ln" cx="593" cy="312" r="3"></circle>
                    <circle class="hz__ripple" cx="593" cy="312" r="9"></circle>
                  </>
                )}
              </g>
            ))}

            <!-- elevator: traction motor + cab with up/down arrows -->
            <g class="hz__load" id="hz-elev">
              <line class="hz__stub" x1="424" y1="84" x2="614" y2="84"></line>
              <path class="hz__mini" d={mini(428, 612, 84)}></path>
              <rect class="hz__load-ln" x="616" y="72" width="32" height="24" rx="3"></rect>
              <circle class="hz__load-ln" cx="632" cy="84" r="5"></circle>
              <rect class="hz__load-ln" x="621" y="196" width="22" height="28" rx="2"></rect>
              <path class="hz__load-ln" d="M626 176 l6 -9 6 9"></path>
              <path class="hz__load-ln" d="M626 240 l6 9 6 -9"></path>
              <circle class="hz__ripple" cx="632" cy="84" r="9"></circle>
            </g>

            <!-- sparks riding the riser while the building is dirty -->
            <circle class="hz__spark" id="hz-spark1" r="2.6"></circle>
            <circle class="hz__spark" id="hz-spark2" r="2"></circle>
            <circle class="hz__spark" id="hz-spark3" r="2.3"></circle>
            <circle class="hz__spark" id="hz-spark4" r="1.7"></circle>
          </g>

          <!-- harmonizer: the shield, pressed against the building -->
          <g class="hz__box" id="hz-box" transform="translate(0,-230)">
            <rect class="hz__box-body" x="326" y="232" width="92" height="96" rx="7"></rect>
            <line class="hz__box-line" x1="342" y1="258" x2="402" y2="258"></line>
            <line class="hz__box-line" x1="342" y1="272" x2="402" y2="272"></line>
            <line class="hz__box-line" x1="342" y1="286" x2="402" y2="286"></line>
            <text class="hz__box-label" x="372" y="308" text-anchor="middle">{t.boxLabel}</text>
            <text class="hz__box-sub" x="372" y="321" text-anchor="middle">{t.boxSub}</text>
          </g>

          <g class="hz__bill" transform="translate(78,34)">
            <text class="hz__meter-label" x="0" y="0">{t.billLabel}</text>
            <text class="hz__bill-name" x="0" y="30">{t.rUseful}</text>
            <text class="hz__bill-amt" x="210" y="30" text-anchor="end">$1,000</text>

            <g class="hz__cost" id="hz-c1">
              <text class="hz__bill-name" x="0" y="58">{t.rHeat}</text>
              <text class="hz__bill-amt hz__cost-amt" x="210" y="58" text-anchor="end">+$90</text>
            </g>
            <g class="hz__cost" id="hz-c2">
              <text class="hz__bill-name" x="0" y="86">{t.rPf}</text>
              <text class="hz__bill-amt hz__cost-amt" x="210" y="86" text-anchor="end">+$35</text>
            </g>

            <g id="hz-credit" class="hz__credit">
              <text class="hz__bill-name hz__bill--mint" x="0" y="114">{t.rHarmo}</text>
              <text class="hz__bill-amt hz__bill--mint" x="210" y="114" text-anchor="end">&#8722;$125</text>
            </g>

            <line class="hz__bill-rule" x1="0" y1="132" x2="210" y2="132"></line>
            <text class="hz__bill-tlabel" x="0" y="158">{t.rPay}</text>
            <text class="hz__bill-total" id="hz-total" x="210" y="160" text-anchor="end">$1,125</text>
            <text class="hz__bill-note" x="0" y="178">{t.billNote}</text>
          </g>
        </svg>
        <aside class="hz__offbill">
          <span class="hz__offbill-eyebrow">{t.offbillEyebrow}</span>
          <p class="hz__offbill-text"><Fragment set:html={t.offbill} /><Disc to="results" lang={lang} /></p>
        </aside>
      </figure>
    </div>
  </div>

  <!-- Mobile walkthrough: the same story as a legible vertical sequence. The
       desktop scroll-scene above is hidden on phones; this is shown instead. -->
  <div class="hz__mobile">
    <div class="container">
      <h2 class="hz__m-title">{t.mTitle}</h2>
      <ol class="hz__m-steps">
        <li class="hz__m-step">
          <span class="hz__m-num">1</span>
          <div class="hz__m-body">
            <p class="hz__m-text">
              {t.mStep1}
            </p>
            <figure class="hz__m-viz hz__m-viz--dirty">
              <svg viewBox="0 0 300 60" role="img" aria-label={t.vizDirtyAria}>
                <path d={mDirtyD} fill="none" stroke="var(--hz-dist)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <figcaption>{t.capDirty}</figcaption>
            </figure>
          </div>
        </li>

        <li class="hz__m-step">
          <span class="hz__m-num">2</span>
          <div class="hz__m-body">
            <p class="hz__m-text">
              {t.mStep2}
            </p>
            <div class="hz__m-bill">
              <p class="hz__m-bill-label">{t.billLabel}</p>
              <div class="hz__m-row"><span>{t.rUseful}</span><span>$1,000</span></div>
              <div class="hz__m-row hz__m-row--cost"><span>{t.rHeat}</span><span>+$90</span></div>
              <div class="hz__m-row hz__m-row--cost"><span>{t.rPf}</span><span>+$35</span></div>
              <div class="hz__m-row hz__m-row--total"><span>{t.rPay}</span><span>$1,125</span></div>
              <p class="hz__m-bill-note">{t.billNote}<Disc to="results" lang={lang} /></p>
            </div>
          </div>
        </li>

        <li class="hz__m-step">
          <span class="hz__m-num">3</span>
          <div class="hz__m-body">
            <p class="hz__m-text">
              {t.mStep3}
            </p>
            <figure class="hz__m-viz hz__m-viz--clean">
              <svg viewBox="0 0 300 60" role="img" aria-label={t.vizCleanAria}>
                <path d={mCleanD} fill="none" stroke="var(--mint)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <figcaption><span class="hz__m-chip">{t.capChip}</span></figcaption>
            </figure>
          </div>
        </li>

        <li class="hz__m-step">
          <span class="hz__m-num">4</span>
          <div class="hz__m-body">
            <p class="hz__m-text">
              {t.mStep4}
            </p>
            <div class="hz__m-bill hz__m-bill--settled">
              <div class="hz__m-row"><span>{t.rUseful}</span><span>$1,000</span></div>
              <div class="hz__m-row hz__m-row--credit"><span>{t.rHarmo}</span><span>&#8722;$125</span></div>
              <div class="hz__m-row hz__m-row--total hz__m-row--good"><span>{t.rPay}</span><span>$1,000</span></div>
            </div>
            <p class="hz__m-stat"><Fragment set:html={t.mStat} /><Disc to="results" lang={lang} /></p>
          </div>
        </li>
      </ol>

      <aside class="hz__m-offbill">
        <span class="hz__offbill-eyebrow">{t.offbillEyebrow}</span>
        <p class="hz__offbill-text"><Fragment set:html={t.offbill} /><Disc to="results" lang={lang} /></p>
      </aside>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const sec = document.querySelector(".hz");
    if (!sec) return;
    // Phones use the static walkthrough markup; skip the scroll choreography.
    if (matchMedia("(max-width: 720px)").matches) return;
    const $ = (id) => document.getElementById(id);
    const box = $("hz-box");
    const kwh = $("hz-kwh");
    const prog = $("hz-progress");
    const riserRed = $("hz-riser-red");
    const riserMint = $("hz-riser-mint");
    const dropRed = $("hz-drop-red");
    const dropMint = $("hz-drop-mint");
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

    const RISER = 216, DROP = 32;
    const KWH_HI = 14555, KWH_LO = 9000;
    [ [riserRed, RISER], [riserMint, RISER], [dropRed, DROP], [dropMint, DROP] ]
      .forEach(([el, len]) => {
        el.style.strokeDasharray = len;
        el.style.strokeDashoffset = len;
      });

    // choreography completes by ~p 0.75; the rest of the track is a hold
    // beat so the finished building gets a full scroll of quiet
    const loads = [
      { el: $("hz-base"), hot: 0.045, cool: 0.48 },
      { el: $("hz-ptac0"), hot: 0.08, cool: 0.53 },
      { el: $("hz-ptac1"), hot: 0.11, cool: 0.58 },
      { el: $("hz-ptac2"), hot: 0.14, cool: 0.63 },
      { el: $("hz-elev"), hot: 0.17, cool: 0.67 },
    ];
    const winRows = [0, 1, 2, 3, 4].map((i) => ({
      el: $("hz-w" + i), at: 0.68 + i * 0.016,
    }));

    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
    const smooth = (p, a, b) => {
      const t = clamp((p - a) / (b - a), 0, 1);
      return t * t * (3 - 2 * t);
    };
    const fmtK = (n) => Math.round(n).toLocaleString("en-US");
    const rectD = $("hz-rect-d");

    // card copy is provided per-locale via the section's data-cards attribute
    let cards = [];
    try { cards = JSON.parse(sec.dataset.cards || "[]"); } catch (e) { cards = []; }
    const card = $("hz-card");
    const cardText = $("hz-card-text");
    const cardNum = $("hz-card-num");
    const setCard = (phase) => {
      const swap = () => {
        cardText.textContent = cards[phase];
        cardNum.textContent = (phase + 1) + " / 4";
      };
      if (reduce) { swap(); return; }
      card.classList.add("is-exit");
      setTimeout(() => {
        swap();
        card.classList.remove("is-exit");
        card.classList.add("is-enter");
        requestAnimationFrame(() => requestAnimationFrame(() => card.classList.remove("is-enter")));
      }, 240);
    };
    let lastPhase = -1;
    let infectNow = 0, climbNow = 0;

    const apply = (p) => {
      const infect = smooth(p, 0, 0.18);
      const drop = smooth(p, 0.2, 0.33);
      const climb = smooth(p, 0.38, 0.66);
      infectNow = infect; climbNow = climb;

      riserRed.style.strokeDashoffset = (RISER * (1 - infect)).toFixed(1);
      dropRed.style.strokeDashoffset = (DROP * (1 - Math.min(infect * 3, 1))).toFixed(1);
      riserMint.style.strokeDashoffset = (RISER * (1 - climb)).toFixed(1);
      dropMint.style.strokeDashoffset = (DROP * (1 - Math.min(climb * 4, 1))).toFixed(1);

      box.setAttribute("transform", "translate(0," + (-230 * (1 - drop)).toFixed(1) + ")");
      box.style.opacity = (0.15 + 0.85 * drop).toFixed(2);

      // the dirty wave reaches the building until the shield seats, then is
      // clipped back to the shield's left edge (no dead gap on the line)
      rectD.setAttribute("width", (418 - 92 * drop - 80).toFixed(1));

      loads.forEach((l) => {
        const cooled = p >= l.cool;
        l.el.classList.toggle("is-hot", p > l.hot && !cooled);
        l.el.classList.toggle("is-cool", cooled);
      });
      winRows.forEach((w) => w.el.classList.toggle("is-warm", p > w.at));

      if (kwh) {
        kwh.textContent = fmtK(KWH_HI - (KWH_HI - KWH_LO) * climb);
        kwh.classList.toggle("is-good", climb > 0.6);
      }

      // the bill, left side: the foam credit lands and the total falls back
      // toward the useful-energy line as the harmonizer seats
      // cost lines appear one by one as the scroll advances
      [["hz-c1", 0.07], ["hz-c2", 0.16]].forEach(
        ([id, th]) => { const el = $(id); if (el) el.style.opacity = p > th ? "1" : "0"; },
      );
      const credit = $("hz-credit");
      const total = $("hz-total");
      credit.style.opacity = climb.toFixed(2);
      total.textContent = "$" + fmtK(1125 - 125 * climb);
      total.classList.toggle("is-good", climb > 0.6);
      sec.classList.toggle("is-deferred", p > 0.66);
      sec.classList.toggle("is-settled", p > 0.75);
      sec.classList.toggle("is-offbill", p > 0.9);
      if (prog) prog.style.transform = "scaleX(" + p.toFixed(3) + ")";
    };

    // sparks are pure decoration; skip the rAF loop under reduced motion
    if (!reduce) try {
      const sparks = [
        { el: $("hz-spark1"), dur: 2600, off: 0 },
        { el: $("hz-spark2"), dur: 3900, off: 0.5 },
        { el: $("hz-spark3"), dur: 3100, off: 0.25 },
        { el: $("hz-spark4"), dur: 4500, off: 0.75 },
      ].filter((s) => s.el);
      const len = riserRed.getTotalLength();
      if (len > 0) {
        const t0 = performance.now();
        const loop = (now) => {
          const vis = infectNow * (1 - climbNow);
          for (const s of sparks) {
            const t = (((now - t0) / s.dur) + s.off) % 1;
            // noise is emitted by the devices: sparks travel DOWN the riser,
            // from the infected front back toward the panel
            const pt = riserRed.getPointAtLength((1 - t) * infectNow * len);
            s.el.setAttribute("cx", pt.x.toFixed(1));
            s.el.setAttribute("cy", pt.y.toFixed(1));
            s.el.style.opacity = (vis * (0.55 + 0.45 * Math.sin(now / 130 + s.off * 7))).toFixed(2);
          }
          requestAnimationFrame(loop);
        };
        requestAnimationFrame(loop);
      }
    } catch (e) { /* decoration only */ }

    // ── click-driven walkthrough (replaces the old sticky scroll-scrub) ──
    // Each card maps to a representative point in the figure's choreography;
    // the arrows tween the figure to that point. No scroll is ever captured.
    const REP = [0.10, 0.19, 0.64, 1.0];
    const prevBtn = $("hz-prev");
    const nextBtn = $("hz-next");
    const navCount = $("hz-nav-count");
    const nextLabel = $("hz-next-label");
    let phase = 0;
    let curP = REP[0];
    let rafTween = 0;

    const easeIO = (t) => (t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2);
    const animateTo = (target) => {
      cancelAnimationFrame(rafTween);
      if (reduce) { curP = target; apply(target); return; }
      const start = curP, t0 = performance.now(), dur = 650;
      const stepF = (now) => {
        const t = clamp((now - t0) / dur, 0, 1);
        curP = start + (target - start) * easeIO(t);
        apply(curP);
        if (t < 1) rafTween = requestAnimationFrame(stepF);
      };
      rafTween = requestAnimationFrame(stepF);
    };

    const updateNav = () => {
      if (prevBtn) prevBtn.disabled = phase === 0;
      if (nextBtn) nextBtn.disabled = phase === REP.length - 1;
      if (navCount) navCount.textContent = (phase + 1) + " / " + REP.length;
    };
    const goTo = (n) => {
      n = clamp(n, 0, REP.length - 1);
      if (n === phase) return;
      phase = n;
      setCard(phase);
      animateTo(REP[phase]);
      updateNav();
      if (phase >= 1 && nextBtn) {
        // first advance: the dramatic starter cue calms to a plain Next arrow
        nextBtn.classList.remove("is-cue");
        if (nextLabel) nextLabel.textContent = sec.dataset.nextAfter || "Next";
      }
    };
    if (nextBtn) nextBtn.addEventListener("click", () => goTo(phase + 1));
    if (prevBtn) prevBtn.addEventListener("click", () => goTo(phase - 1));

    apply(curP);
    updateNav();
  })();
</script>

