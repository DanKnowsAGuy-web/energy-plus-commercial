---
import logo from "../assets/energy-plus-logo.png";

interface Props {
  lang?: "en" | "es";
}
const { lang = "en" } = Astro.props;

// locale roots (respect the GitHub Pages base path)
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const enHref = base;
const esHref = base + "es/";

const t = {
  en: {
    home: "Energy Plus, home",
    problem: "The problem",
    find: "What we find",
    proof: "Proof",
    calc: "Calculator",
    apply: "Apply Now",
    nav: "Primary",
  },
  es: {
    home: "Energy Plus, inicio",
    problem: "El problema",
    find: "Lo que encontramos",
    proof: "Pruebas",
    calc: "Calculadora",
    apply: "Solicitar ahora",
    nav: "Principal",
  },
}[lang];
---

<header class="site-header" id="top">
  <div class="container site-header__inner">
    <div class="site-header__lockup">
      <a href="#top" class="wordmark" aria-label={t.home}>
        <img class="wordmark__logo" src={logo.src} width="118" height="34" alt="Energy Plus" />
      </a>
      <span class="wordmark__div" aria-hidden="true"></span>
      <div class="lang-toggle" role="group" aria-label="Language / Idioma">
        <a
          href={enHref}
          class={"lang-toggle__btn" + (lang === "en" ? " is-active" : "")}
          aria-current={lang === "en" ? "true" : undefined}
          lang="en"
        >EN</a>
        <span class="lang-toggle__sep" aria-hidden="true">|</span>
        <a
          href={esHref}
          class={"lang-toggle__btn" + (lang === "es" ? " is-active" : "")}
          aria-current={lang === "es" ? "true" : undefined}
          lang="es"
        >ES</a>
      </div>
    </div>

    <nav class="site-nav" aria-label={t.nav}>
      <a href="#problem" class="site-nav__link">{t.problem}</a>
      <a href="#what-we-find" class="site-nav__link">{t.find}</a>
      <a href="#proof" class="site-nav__link">{t.proof}</a>
      <a href="#calculator" class="site-nav__link">{t.calc}</a>
      <a href="#book" class="btn site-header__cta">
        {t.apply}
        <span class="btn__arrow" aria-hidden="true">&rarr;</span>
      </a>
    </nav>
  </div>
</header>

<style>
  /* non-sticky: the bar scrolls away so it never overlaps the pinned
     power-quality scene below. */
  .site-header {
    position: relative;
    z-index: var(--z-header);
    background: var(--bg-header);
    border-bottom: 1px solid var(--line);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 68px;
    gap: var(--space-m);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--ink);
  }
  .wordmark__logo {
    height: 30px;
    width: auto;
    display: block;
  }
  .wordmark__div {
    width: 1px;
    height: 22px;
    background: var(--line-strong);
  }

  /* logo | language toggle */
  .site-header__lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
  }
  .lang-toggle__btn {
    color: var(--muted);
    text-decoration: none;
    padding: 0.15em 0.1em;
    transition: color 0.2s ease;
  }
  .lang-toggle__btn:hover {
    color: var(--ink);
  }
  .lang-toggle__btn.is-active {
    color: var(--gold-text);
  }
  .lang-toggle__sep {
    color: var(--line-strong);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.6vw, 2.2rem);
  }
  .site-nav__link {
    position: relative;
    color: var(--body);
    text-decoration: none;
    font-size: var(--step--1);
    font-weight: 500;
    transition: color 0.25s ease;
  }
  .site-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 1px;
    background: var(--gold-text);
    transform: scaleX(0);
    transform-origin: 0 50%;
    transition: transform 0.3s var(--ease-out-quart);
  }
  .site-nav__link:hover {
    color: var(--ink);
  }
  .site-nav__link:hover::after {
    transform: scaleX(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .site-nav__link::after {
      transition: none;
    }
  }

  .site-header__cta {
    padding: 0.65em 1.1em;
    font-size: var(--step--1);
  }

  @media (max-width: 720px) {
    .site-nav__link {
      display: none;
    }
    /* the long pill overflowed onto the wordmark; the hero CTA sits right
       below, so the header is just the brand on small screens */
    .site-header__cta {
      display: none;
    }
  }
</style>
