---
// Compact "trusted by results" band: three named, field-measured case results
// directly under the hero. The names carry the credibility (a hospital, a known
// category), so this reads as proof, not a vanity stat bar. Same three results
// the calculator opens with. Links down to the full verified record.
interface Props {
  lang?: "en" | "es";
}
const { lang = "en" } = Astro.props;

const t = {
  en: {
    lead: "Measured in the field by independent analysts, not modeled.",
    more: "200+ verified results",
    items: [
      { fig: "$180K", suf: "/yr", name: "Edward Hospital", meta: "Illinois · whole facility" },
      { fig: "49%", suf: "", name: "Arizona Ford Dealership", meta: "full-stack program" },
      { fig: "33%", suf: "", name: "Midwest Bottling Facility", meta: "manufacturing" },
    ],
  },
  es: {
    lead: "Medido en campo por analistas independientes, no modelado.",
    more: "Más de 200 resultados verificados",
    items: [
      { fig: "$180K", suf: "/año", name: "Edward Hospital", meta: "Illinois · instalación completa" },
      { fig: "49%", suf: "", name: "Concesionario Ford en Arizona", meta: "programa integral" },
      { fig: "33%", suf: "", name: "Planta embotelladora del Medio Oeste", meta: "manufactura" },
    ],
  },
}[lang];
---

<section class="tps" aria-label="Verified results">
  <div class="container tps__inner">
    <p class="tps__lead">{t.lead}</p>
    <ul class="tps__grid">
      {t.items.map((it) => (
        <li class="tps__item">
          <span class="tps__fig">{it.fig}<span class="tps__suf">{it.suf}</span></span>
          <span class="tps__name">{it.name}</span>
          <span class="tps__meta">{it.meta}</span>
        </li>
      ))}
    </ul>
    <a class="tps__more" href="#proof">
      {t.more}
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
    </a>
  </div>
</section>

<style>
  .tps {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--surface) 55%, transparent);
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
  }
  .tps__lead {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-bottom: clamp(1rem, 3vw, 1.5rem);
  }
  .tps__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 4vw, 3rem);
  }
  .tps__item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-left: clamp(1rem, 2.5vw, 1.75rem);
    border-left: 1px solid var(--line-strong);
  }
  .tps__item:first-child { padding-left: 0; border-left: none; }
  .tps__fig {
    font-family: var(--font-serif);
    font-size: clamp(2.1rem, 4.5vw, 3.1rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--gold-text);
  }
  .tps__suf {
    font-size: 0.42em;
    font-family: var(--font-mono);
    color: var(--muted);
    letter-spacing: 0.02em;
    margin-left: 0.15em;
  }
  .tps__name {
    margin-top: 0.45rem;
    font-size: var(--step-0);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.25;
  }
  .tps__meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: var(--muted);
  }
  .tps__more {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    margin-top: clamp(1.25rem, 3vw, 1.75rem);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.03em;
    color: var(--gold-text);
    text-decoration: none;
    transition: gap 0.25s var(--ease-out-quart);
  }
  .tps__more svg { width: 1.05em; height: 1.05em; }
  .tps__more:hover { gap: 0.8em; }

  @media (max-width: 640px) {
    .tps__grid { grid-template-columns: 1fr; gap: 1.1rem; }
    .tps__item {
      padding-left: 0;
      border-left: none;
      border-top: 1px solid var(--line);
      padding-top: 1.1rem;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0.2rem 0.8rem;
    }
    .tps__item:first-child { border-top: none; padding-top: 0; }
    .tps__name { margin-top: 0; }
    .tps__meta { flex-basis: 100%; }
  }
</style>
