---
// RESEQUENCED preview variant ("two doors, one path"). Fast path first:
// hero -> the floor number -> the offer capsule + CTA -> calculator. Then the
// method/proof depth layer for skeptics. The canonical Page.astro is unchanged;
// this exists only at /preview/ for side-by-side comparison.
import Base from "../layouts/Base.astro";
import Header from "./Header.astro";
import Hero from "./HeroInstrument.astro";
import FloorStat from "./FloorStat.astro";
import Capsule from "./Capsule.astro";
import Estimator from "./Estimator.astro";
import ProblemLean from "./ProblemLean.astro";
import Harmonizer from "./Harmonizer.astro";
import ActFourLean from "./ActFourLean.astro";
import HvacLean from "./HvacLean.astro";
import OfferLean from "./OfferLean.astro";
import Proof from "./Proof.astro";
import Engineer from "./Engineer.astro";
import Success from "./Success.astro";
import Team from "./Team.astro";
import FinalCta from "./FinalCta.astro";
import Footer from "./Footer.astro";

interface Props {
  lang?: "en" | "es";
}
const { lang = "en" } = Astro.props;

const meta = {
  en: {
    title: "Energy Plus: verified energy savings for commercial buildings",
    description:
      "We cut your building's energy costs and prove the savings at your meter before you pay a cent. We even pay for the diagnosis ourselves.",
  },
  es: {
    title: "Energy Plus: ahorro de energía verificado para edificios comerciales",
    description:
      "Reducimos los costos de energía de su edificio y comprobamos el ahorro en su propio medidor antes de que pague un centavo. Incluso pagamos el diagnóstico nosotros mismos.",
  },
} as const;
const m = meta[lang] ?? meta.en;
---

<Base title={m.title} description={m.description} lang={lang}>
  <div class="theme-dark">
    <div class="bp-ambient" data-parallax aria-hidden="true"></div>
    <Header lang={lang} />
    <main id="main">
      {/* --- Fast path: the offer and the tool, before any technical reading --- */}
      <Hero lang={lang} />
      <FloorStat />
      <Capsule lang={lang} />
      <Estimator lang={lang} />

      {/* --- The method: depth layer for operators who want the proof --- */}
      <ProblemLean lang={lang} />
      <Harmonizer lang={lang} />
      <ActFourLean lang={lang} />
      <HvacLean lang={lang} />
      <div class="paper"><OfferLean lang={lang} /></div>
      <div class="paper"><Proof lang={lang} /></div>
      <Engineer lang={lang} />
      <Success lang={lang} />
      <Team lang={lang} />
      <FinalCta lang={lang} />
    </main>
    <Footer lang={lang} />
  </div>
</Base>

<style is:global>
  /* --- Slate graphite: the dominant surface ---------------------------- */
  .theme-dark {
    --bg: #141a1e; --bg-header: #0f1418; --hero-from: #1c2329; --hero-to: #141a1e;
    --surface: #1d242b; --surface-2: #252e36;
    --ink: #eef1ef; --body: #bac2c1; --muted: #8b9592;
    --gold: #1f8390; --gold-text: #46cfd6; --mint: #46cfd6; --cost: #c87a64;
    --h-red: #c87a64; --h-teal: #46cfd6;
    --line: rgba(220, 230, 230, 0.12); --line-strong: rgba(220, 230, 230, 0.2);
    --gold-soft: rgba(31, 131, 144, 0.12); --mint-soft: rgba(70, 207, 214, 0.13);
    --shadow-lift: 0 1px 0 rgba(255, 255, 255, 0.06) inset, 0 22px 50px -24px rgba(0, 0, 0, 0.85);
    --shadow-tilt: 0 1px 0 rgba(255, 255, 255, 0.08) inset, 0 36px 70px -28px rgba(0, 0, 0, 0.92),
      0 0 0 1px color-mix(in srgb, var(--gold) 32%, transparent);
    --font-serif: "Newsreader Variable", "Newsreader", Georgia, "Times New Roman", serif;
    --font-sans: "Hanken Grotesk", system-ui, sans-serif;
    --font-mono: "Geist Mono", ui-monospace, monospace;
    background: #141a1e; color: #eef1ef;
  }

  .theme-dark :is(.offerl__box, .probl__panel, .step, .win__col, .eng__card,
    .eng__tile, .eng__photo, .est__measured, .hz__card, .case) {
    box-shadow: var(--shadow-lift);
  }
  .theme-dark :is(.case, .eng__card, .eng__tile, .probl__panel, .offerl__box,
    .win__col, .step, .est__measured) {
    transform-style: preserve-3d;
    transition: transform 0.5s var(--ease-out-quart), box-shadow 0.5s ease;
    will-change: transform;
  }
  .theme-dark .is-tilting {
    transition: transform 0.07s linear, box-shadow 0.25s ease;
    box-shadow: var(--shadow-tilt);
    z-index: 2;
  }

  .bp-ambient {
    position: fixed; inset: -8%; z-index: 0; pointer-events: none;
    background:
      radial-gradient(42% 34% at 14% 18%, color-mix(in srgb, var(--mint) 42%, transparent), transparent 68%),
      radial-gradient(48% 42% at 90% 52%, color-mix(in srgb, var(--gold) 38%, transparent), transparent 70%),
      radial-gradient(44% 36% at 52% 98%, color-mix(in srgb, var(--cost) 26%, transparent), transparent 68%);
    mix-blend-mode: screen;
    opacity: 0.75;
    transform: translate3d(var(--px, 0), var(--py, 0), 0);
    transition: transform 0.7s var(--ease-out-quart);
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .bp-ambient { transition: none; transform: none; }
  }
  .theme-dark .paper { position: relative; z-index: 1; }

  .theme-dark .btn {
    position: relative; overflow: hidden;
    transform: translate(var(--bx, 0px), var(--by, 0px));
    transition: transform 0.3s var(--ease-out-quart), background-color 0.3s ease;
  }
  .theme-dark .btn:hover { transform: translate(var(--bx, 0px), calc(var(--by, 0px) - 2px)); }
  .theme-dark .btn::after {
    content: ""; position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(90px circle at var(--mx, 50%) var(--my, 50%),
      color-mix(in srgb, var(--gold) 55%, transparent), transparent 60%);
    mix-blend-mode: soft-light;
    opacity: 0; transition: opacity 0.35s ease;
  }
  .theme-dark .btn:hover::after { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .theme-dark .btn { transform: none; }
    .theme-dark .btn:hover { transform: translateY(-2px); }
  }
  .theme-dark .btn { background: var(--ink); color: var(--bg); }
  .theme-dark .btn:hover { background: #ffffff; box-shadow: none; }
  .theme-dark .afl__fig { color: var(--cost) !important; }

  .theme-dark .paper {
    --bg: #d4d8d2; --surface: #dde0da; --surface-2: #cbcfc9;
    --ink: #1a1d1a; --body: #3c413b; --muted: #5d625b;
    --gold: #0a5a63; --gold-text: #0a5a63; --mint: #0a5a63; --cost: #8f4030;
    --h-red: #8f4030; --h-teal: #0a5a63;
    --line: rgba(20, 25, 20, 0.14); --line-strong: rgba(20, 25, 20, 0.22);
    --gold-soft: rgba(10, 90, 99, 0.09); --mint-soft: rgba(10, 90, 99, 0.12);
    --shadow-lift: 0 1px 0 rgba(255, 255, 255, 0.6) inset, 0 16px 40px -28px rgba(0, 0, 0, 0.22);
    background: #d4d8d2; color: #1a1d1a;
  }
  .theme-dark .paper .btn:hover { background: #2f352e; }
</style>
